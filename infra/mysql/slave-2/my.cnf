[mysqld]
# ===== Slave 2 식별 =====
server-id=3

# ===== 릴레이 로그 (Master binlog를 받아 재생) =====
relay-log=mysql-relay-bin
read_only=1

# ===== 레플리케이션 대상 DB =====
replicate-do-db=ticket

# ===== 성능 설정 =====
max_connections=500
innodb_buffer_pool_size=512M
innodb_log_file_size=128M

# ===== 문자셋 =====
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
