<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ticketrush.centralserver.infrastructure.persistence.mapper.PaymentQueryMapper">

    <insert id="insertPayment">
        INSERT INTO payment (
            reservation_id,
            amount,
            status,
            method
        )
        VALUES (
            #{reservationId},
            #{amount},
            #{status},
            #{method}
        )
    </insert>

    <select id="findIdByReservationId" resultType="java.lang.Long">
        SELECT id
        FROM payment
        WHERE reservation_id = #{reservationId}
    </select>

</mapper>