<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ticketrush.centralserver.infrastructure.persistence.mapper.ScheduleQueryMapper">

    <select id="findByPerformanceId" resultType="com.ticketrush.centralserver.infrastructure.persistence.model.ScheduleRow">
        SELECT
            id,
            performance_id,
            start_time,
            end_time,
            status
        FROM schedule
        WHERE performance_id = #{performanceId}
        ORDER BY start_time ASC, id ASC
    </select>

</mapper>
